<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="IntelliFillOCR.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="IntelliFill OCR">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid>
        <NavigationView
            x:Name="ShellNavigation"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            PaneDisplayMode="Left"
            SelectionChanged="ShellNavigation_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Workspace" Icon="Home" Tag="workspace" IsSelected="True" />
                <NavigationViewItem Content="Extraction" Icon="Document" Tag="extraction" />
                <NavigationViewItem Content="Database" Icon="Library" Tag="database" />
                <NavigationViewItem Content="Settings" Icon="Setting" Tag="settings" />
            </NavigationView.MenuItems>
            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="About v3.0.0" Icon="Help" Tag="about" />
            </NavigationView.FooterMenuItems>

            <Grid RowDefinitions="Auto,*" Padding="28,22,28,24" RowSpacing="18">
                <InfoBar
                    x:Name="StatusInfoBar"
                    IsOpen="False"
                    Severity="Informational"
                    IsClosable="True" />

                <ScrollViewer Grid.Row="1">
                    <StackPanel Spacing="18">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="18">
                            <Image
                                Source="/Assets/StoreLogo.png"
                                Width="72"
                                Height="72"
                                Stretch="Uniform" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                                <TextBlock Text="IntelliFill OCR" Style="{ThemeResource TitleTextBlockStyle}" />
                                <TextBlock
                                    Text="Native WinUI 3 shell for offline OCR extraction and table filling"
                                    Style="{ThemeResource BodyTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <Button
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                Click="LaunchWorkspaceButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8A7;" />
                                    <TextBlock Text="Open OCR Workspace" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Grid ColumnDefinitions="2*,*" ColumnSpacing="18">
                            <Border
                                Padding="20"
                                BorderBrush="{ThemeResource CardStrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <StackPanel Spacing="16">
                                    <TextBlock Text="v3 Native Shell" Style="{ThemeResource SubtitleTextBlockStyle}" />
                                    <TextBlock
                                        Text="This WinUI 3 frontend is the new Windows platform shell. The current Python OCR engine, document processing, SQLite storage, and exports remain available while the native screens are migrated."
                                        TextWrapping="WrapWholeWords"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" RowDefinitions="Auto,Auto" RowSpacing="12">
                                        <Button Click="LaunchWorkspaceButton_Click" HorizontalAlignment="Stretch">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE8B7;" />
                                                <TextBlock Text="Launch full OCR workflow" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="1" Click="OpenRepositoryButton_Click" HorizontalAlignment="Stretch">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE838;" />
                                                <TextBlock Text="Open project folder" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Row="1" Click="OpenPythonSettingsButton_Click" HorizontalAlignment="Stretch">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE713;" />
                                                <TextBlock Text="Open app data" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Row="1" Grid.Column="1" Click="RefreshStatusButton_Click" HorizontalAlignment="Stretch">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE72C;" />
                                                <TextBlock Text="Refresh status" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border
                                Grid.Column="1"
                                Padding="20"
                                BorderBrush="{ThemeResource CardStrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Backend Status" Style="{ThemeResource SubtitleTextBlockStyle}" />
                                    <TextBlock x:Name="BackendStatusText" TextWrapping="WrapWholeWords" />
                                    <ProgressRing x:Name="BusyRing" IsActive="False" Width="32" Height="32" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border
                            Padding="20"
                            BorderBrush="{ThemeResource CardStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="14">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Template First" FontWeight="SemiBold" />
                                    <TextBlock Text="Upload templates, preserve multi-table layouts, and fill blank cells." TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="6">
                                    <TextBlock Text="Offline OCR" FontWeight="SemiBold" />
                                    <TextBlock Text="Tesseract, OpenCV preprocessing, parsed text, and region selection stay local." TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="6">
                                    <TextBlock Text="Traceable Exports" FontWeight="SemiBold" />
                                    <TextBlock Text="SQLite storage, barcode traceability, Word/PDF/Excel exports, and validation." TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </NavigationView>
    </Grid>
</Window>
