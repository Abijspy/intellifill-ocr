<Window
    x:Class="IntelliFillOCR.Avalonia.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="IntelliFill OCR"
    Icon="avares://IntelliFillOCR/Assets/app.ico"
    Width="1360"
    Height="820"
    MinWidth="980"
    MinHeight="640"
    FontFamily="Segoe UI"
    Background="{DynamicResource AppBackgroundBrush}">

    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#EAF2FF" />
        <SolidColorBrush x:Key="ShellBrush" Color="#FBFCFF" />
        <SolidColorBrush x:Key="ShellRailBrush" Color="#EEF4FF" />
        <SolidColorBrush x:Key="ShellCardBrush" Color="#F2F5FE" />
        <SolidColorBrush x:Key="ShellBorderBrush" Color="#DDE5F5" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FBFCFF" />
        <SolidColorBrush x:Key="SoftPanelBrush" Color="#F2F5FE" />
        <SolidColorBrush x:Key="PreviewPanelBrush" Color="#F8FAFF" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#DDE5F5" />
        <SolidColorBrush x:Key="TitleTextBrush" Color="#282B36" />
        <SolidColorBrush x:Key="BodyTextBrush" Color="#2B2E3A" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#687083" />
        <SolidColorBrush x:Key="ShellTitleTextBrush" Color="#282B36" />
        <SolidColorBrush x:Key="ShellBodyTextBrush" Color="#2B2E3A" />
        <SolidColorBrush x:Key="ShellMutedTextBrush" Color="#687083" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="TealBrush" Color="#14B8A6" />
        <SolidColorBrush x:Key="TealTextBrush" Color="#071318" />
        <SolidColorBrush x:Key="RailButtonBrush" Color="#E8EEF9" />
        <SolidColorBrush x:Key="RailButtonTextBrush" Color="#263044" />
        <SolidColorBrush x:Key="RailButtonBorderBrush" Color="#CDD8EC" />
        <SolidColorBrush x:Key="PreviewCanvasBrush" Color="#EEF3FF" />
        <SolidColorBrush x:Key="SelectionStrokeBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="SelectionFillBrush" Color="#332563EB" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Border.darkShell">
            <Setter Property="Background" Value="{DynamicResource ShellBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ShellBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>
        <Style Selector="Border.darkCard">
            <Setter Property="Background" Value="{DynamicResource ShellCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ShellBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="12" />
        </Style>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Padding" Value="18" />
        </Style>
        <Style Selector="Border.softPanel">
            <Setter Property="Background" Value="{DynamicResource SoftPanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <Style Selector="Border.previewPanel">
            <Setter Property="Background" Value="{DynamicResource PreviewPanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="14" />
        </Style>
        <Style Selector="TextBlock.kicker">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Opacity" Value="0.72" />
        </Style>
        <Style Selector="TextBlock.darkMuted">
            <Setter Property="Foreground" Value="{DynamicResource ShellMutedTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="TextBlock.title">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TitleTextBrush}" />
        </Style>
        <Style Selector="TextBlock.sectionTitle">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource BodyTextBrush}" />
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="Button">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.teal">
            <Setter Property="Background" Value="{DynamicResource TealBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TealTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.rail">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Background" Value="{DynamicResource RailButtonBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource RailButtonTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource RailButtonBorderBrush}" />
        </Style>
        <Style Selector="Button.iconRail">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource RailButtonBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource RailButtonTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource RailButtonBorderBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.pageTab">
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="Background" Value="{DynamicResource RailButtonBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource RailButtonTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource RailButtonBorderBrush}" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TextBox.mono">
            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, monospace" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Background" Value="{DynamicResource PreviewPanelBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource BodyTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10,7" />
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Background" Value="{DynamicResource PreviewPanelBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource BodyTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10,6" />
        </Style>
        <Style Selector="ListBox">
            <Setter Property="Background" Value="{DynamicResource PreviewPanelBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource BodyTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Styles>

    <Grid Margin="16">
        <Border x:Name="AppShell" Classes="panel">
            <Grid RowDefinitions="Auto,*" RowSpacing="14">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                    <Image Source="avares://IntelliFillOCR/Assets/logo_512.png" Width="46" Height="46" Stretch="Uniform" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Spacing="3">
                        <TextBlock Text="IntelliFill OCR" Classes="title" />
                        <TextBlock Text="A calm desktop workflow for source review, visual OCR selection, mapping, validation, and export." Classes="muted" />
                    </StackPanel>
                    <Border Grid.Column="2" Classes="softPanel" Padding="16,10" VerticalAlignment="Center">
                        <TextBlock x:Name="VersionBadgeText" Text="v3.7.4" FontWeight="SemiBold" Foreground="{DynamicResource BodyTextBrush}" />
                    </Border>
                </Grid>

                <Grid Grid.Row="1" RowDefinitions="Auto,*" RowSpacing="14">
                    <Border Classes="softPanel" Padding="10">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button x:Name="TemplatePageButton" Classes="pageTab primary" Click="ShowTemplatePage_Click" Content="Template" />
                                <Button x:Name="SourcesPageButton" Classes="pageTab" Click="ShowSourcesPage_Click" Content="Sources" />
                                <Button x:Name="MappingPageButton" Classes="pageTab" Click="ShowMappingPage_Click" Content="Mapping" />
                                <Button x:Name="ReviewPageButton" Classes="pageTab" Click="ShowReviewPage_Click" Content="Review" />
                                <Button x:Name="SettingsPageButton" Classes="pageTab" Click="ShowSettingsPage_Click" Content="Settings" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Grid Grid.Row="1">
                        <ScrollViewer x:Name="TemplatePage" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Spacing="14" Margin="0,14,8,72">
                                <Border Classes="softPanel">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="Template Document" Classes="sectionTitle" />
                                            <TextBox x:Name="TemplatePathBox" IsReadOnly="True" PlaceholderText="No template loaded" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
                                            <Button Classes="primary" Click="UploadTemplate_Click" Content="Upload Template" />
                                            <Button Click="AutoFill_Click" Content="Auto Fill" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Classes="softPanel">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="Detected Tables" Classes="sectionTitle" />
                                        <ComboBox x:Name="TemplateTableSelector" SelectionChanged="TemplateTableSelector_SelectionChanged" />
                                        <TextBlock x:Name="TemplateSummaryText" Classes="muted" />
                                        <Separator />
                                        <TextBlock Text="Next Step" Classes="sectionTitle" />
                                        <TextBlock Text="Open Mapping to fill destination cells. Export includes every detected output table in one document." Classes="muted" />
                                    </StackPanel>
                                </Border>

                                <Border Classes="previewPanel">
                                    <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                                        <TextBlock Text="Template Preview" Classes="sectionTitle" />
                                        <ScrollViewer Grid.Row="1" MinHeight="280" MaxHeight="430" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                            <Grid x:Name="TemplatePreviewGrid" />
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <ScrollViewer x:Name="SourcesPage" IsVisible="False" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Spacing="14" Margin="0,14,8,72">
                                <Border Classes="softPanel">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Source Documents" Classes="sectionTitle" />
                                            <TextBlock x:Name="SelectedDocumentText" Text="Upload and select a document." Classes="muted" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <Button Classes="primary" Click="UploadSources_Click" Content="Upload Sources" />
                                            <Button Click="OpenOriginal_Click" Content="Open Original" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <StackPanel Spacing="14">
                                    <Border Classes="softPanel">
                                        <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                                            <TextBlock Text="Files" Classes="sectionTitle" />
                                            <ListBox x:Name="DocumentsListBox" Grid.Row="1" MinHeight="120" MaxHeight="220" SelectionChanged="DocumentsListBox_SelectionChanged" />
                                        </Grid>
                                    </Border>

                                    <StackPanel Spacing="12">
                                        <Border Classes="softPanel">
                                            <StackPanel Spacing="10">
                                                <ComboBox x:Name="SourceTableSelector" SelectionChanged="SourceTableSelector_SelectionChanged" />
                                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <Button Click="ZoomOut_Click" Content="-" ToolTip.Tip="Zoom out" />
                                                        <Button Click="ZoomIn_Click" Content="+" ToolTip.Tip="Zoom in" />
                                                        <Button Click="ResetPreview_Click" Content="Reset" />
                                                        <Button Click="RotateLeft_Click" Content="Left" />
                                                        <Button Click="RotateRight_Click" Content="Right" />
                                                        <Button Classes="primary" Click="EnableRegionSelection_Click" Content="Select Region" />
                                                        <TextBlock x:Name="ZoomText" Text="100% / 0°" VerticalAlignment="Center" MinWidth="92" Foreground="{DynamicResource BodyTextBrush}" />
                                                    </StackPanel>
                                                </ScrollViewer>
                                            </StackPanel>
                                        </Border>

                                        <Border Classes="previewPanel">
                                            <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBlock Text="Large Visual Preview" Classes="sectionTitle" />
                                                    <TextBlock x:Name="RegionSelectionText" Grid.Column="1" Text="No region selected" Classes="muted" VerticalAlignment="Center" />
                                                </Grid>
                                                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                                    <Canvas x:Name="PreviewCanvas" Width="1120" Height="760" Background="{DynamicResource PreviewCanvasBrush}" PointerPressed="PreviewCanvas_PointerPressed" PointerMoved="PreviewCanvas_PointerMoved" PointerReleased="PreviewCanvas_PointerReleased">
                                                        <Image x:Name="PreviewImage" Width="1120" Height="760" Stretch="Uniform" IsVisible="False" />
                                                        <TextBlock x:Name="PreviewMessage" Width="1000" Canvas.Left="60" Canvas.Top="350" TextAlignment="Center" TextWrapping="Wrap" Text="Image and PDF region selection preview appears here. Use zoom, rotate, and Select Region for accurate OCR windows." Foreground="{DynamicResource MutedTextBrush}" />
                                                        <Rectangle x:Name="PreviewRegionRectangle" IsVisible="False" Stroke="{DynamicResource SelectionStrokeBrush}" StrokeThickness="2" Fill="{DynamicResource SelectionFillBrush}" />
                                                    </Canvas>
                                                </ScrollViewer>
                                            </Grid>
                                        </Border>

                                        <Border Classes="softPanel">
                                            <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                                                <TextBlock Text="Detected Source Table" Classes="sectionTitle" />
                                                <ScrollViewer Grid.Row="1" MinHeight="160" MaxHeight="280" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                                    <Grid x:Name="SourceTablePreviewGrid" />
                                                </ScrollViewer>
                                            </Grid>
                                        </Border>

                                        <Border Classes="softPanel">
                                            <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
                                                <TextBlock Text="Parsed Text" Classes="sectionTitle" />
                                                <TextBox x:Name="ParsedTextBox" Grid.Row="1" MinHeight="160" MaxHeight="260" PlaceholderText="Parsed text from selected document" AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True" Classes="mono" />
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <ScrollViewer x:Name="MappingPage" IsVisible="False" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Spacing="14" Margin="0,14,8,72">
                                <Border Classes="softPanel">
                                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="12">
                                        <TextBlock Text="Extracted Fields" Classes="sectionTitle" />
                                        <ListBox x:Name="ExtractedFieldsListBox" Grid.Row="1" MinHeight="180" MaxHeight="280" SelectionChanged="ExtractedFieldsListBox_SelectionChanged" />
                                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
                                            <Button Classes="primary" Click="MapSelected_Click" Content="Map Selected" />
                                            <Button Click="AutoFill_Click" Content="Auto Fill" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Classes="previewPanel">
                                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                            <StackPanel>
                                                <TextBlock Text="Destination Table" Classes="sectionTitle" />
                                                <TextBlock x:Name="OutputSelectionText" Text="Select a destination cell, then map an extracted field." Classes="muted" />
                                            </StackPanel>
                                            <ComboBox x:Name="OutputTableSelector" Grid.Column="1" MinWidth="220" SelectionChanged="OutputTableSelector_SelectionChanged" />
                                        </Grid>
                                        <Separator Grid.Row="1" />
                                        <ScrollViewer Grid.Row="2" MinHeight="300" MaxHeight="460" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                            <Grid x:Name="OutputPreviewGrid" />
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <ScrollViewer x:Name="ReviewPage" IsVisible="False" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Spacing="14" Margin="0,14,8,72">
                                <Border Classes="softPanel">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="14" RowSpacing="12">
                                        <StackPanel>
                                            <TextBlock Text="Validation and Export" Classes="sectionTitle" />
                                            <TextBlock Text="Review warnings, then export a traceable output document." Classes="muted" />
                                        </StackPanel>
                                        <Border Grid.Column="1" Grid.RowSpan="2" Classes="previewPanel" MinWidth="300" VerticalAlignment="Stretch">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="TRACEABILITY" Classes="kicker" />
                                                <TextBlock x:Name="TraceabilityText" FontWeight="SemiBold" Foreground="{DynamicResource BodyTextBrush}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button Classes="primary" Click="RunValidation_Click" Content="Validate" />
                                                <Button Click="SaveToDatabase_Click" Content="Save SQLite" />
                                                <Button Click="DetectSignatures_Click" Content="Signatures/Stamps" />
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>

                                <Border Classes="previewPanel">
                                    <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                            <StackPanel>
                                                <TextBlock Text="PDF Export Preview" Classes="sectionTitle" />
                                                <TextBlock Text="Rendered from the current output. The final page is shown so the traceability barcode is visible." Classes="muted" />
                                            </StackPanel>
                                            <Button Grid.Column="1" Click="RefreshExportPdfPreview_Click" Content="Refresh Preview" VerticalAlignment="Center" />
                                        </Grid>
                                        <ScrollViewer Grid.Row="1" MinHeight="360" MaxHeight="620" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                            <Grid MinHeight="340" Background="{DynamicResource PreviewCanvasBrush}">
                                                <Image x:Name="ExportPdfPreviewImage" Stretch="Uniform" IsVisible="False" />
                                                <TextBlock x:Name="ExportPdfPreviewMessage" Text="Upload and fill a template to preview the generated PDF." TextAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="720" Foreground="{DynamicResource MutedTextBrush}" />
                                            </Grid>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>

                                <Border Classes="previewPanel">
                                    <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                                        <TextBlock Text="Validation Results" Classes="sectionTitle" />
                                        <TextBox x:Name="ValidationBox" Grid.Row="1" MinHeight="220" MaxHeight="360" AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True" Classes="mono" />
                                    </Grid>
                                </Border>
                                <Border Classes="previewPanel">
                                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                            <StackPanel>
                                                <TextBlock Text="Final Output Preview" Classes="sectionTitle" />
                                                <TextBlock Text="This is the table content that will be saved or exported." Classes="muted" />
                                            </StackPanel>
                                            <ComboBox x:Name="ReviewOutputTableSelector" Grid.Column="1" MinWidth="220" SelectionChanged="ReviewOutputTableSelector_SelectionChanged" />
                                        </Grid>
                                        <Separator Grid.Row="1" />
                                        <ScrollViewer Grid.Row="2" MinHeight="300" MaxHeight="520" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                            <Grid x:Name="ReviewOutputPreviewGrid" />
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                                <Border Classes="softPanel">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Export" Classes="sectionTitle" />
                                        <Button Classes="primary rail" Click="ExportPdf_Click" Content="PDF with Traceability" />
                                        <Button Classes="rail" Click="ExportWord_Click" Content="Word Document" />
                                        <Button Classes="rail" Click="ExportExcel_Click" Content="Excel Workbook" />
                                        <Button Classes="rail" Click="ExportCsv_Click" Content="CSV File" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <ScrollViewer x:Name="SettingsPage" IsVisible="False" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Spacing="14" Margin="0,14,8,72">
                                <Border Classes="softPanel">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                                        <StackPanel>
                                            <TextBlock Text="Settings" Classes="sectionTitle" />
                                            <TextBlock Text="Local OCR, database, theme, logs, updates, and storage tools." Classes="muted" />
                                        </StackPanel>
                                        <Button Grid.Column="1" Classes="primary" Click="ApplyTheme_Click" Content="Save Settings" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>

                                <Border Classes="softPanel">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="Local Paths" Classes="sectionTitle" />
                                        <TextBlock Text="Tesseract OCR" Classes="kicker" />
                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                            <TextBox x:Name="TesseractPathBox" PlaceholderText="Tesseract executable path" />
                                            <Button Grid.Column="1" Click="AutoDetectTesseract_Click" Content="Auto Detect" />
                                            <Button Grid.Column="2" Click="BrowseTesseract_Click" Content="Browse" />
                                        </Grid>
                                        <TextBlock Text="SQLite Database" Classes="kicker" />
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <TextBox x:Name="DatabasePathBox" PlaceholderText="SQLite database path" />
                                            <Button Grid.Column="1" Click="BrowseDatabase_Click" Content="Browse" />
                                        </Grid>
                                        <TextBlock Text="Theme" Classes="kicker" />
                                        <ComboBox x:Name="ThemeComboBox" SelectedIndex="0" MaxWidth="260" HorizontalAlignment="Left">
                                            <ComboBoxItem Content="Use system theme" />
                                            <ComboBoxItem Content="Light" />
                                            <ComboBoxItem Content="Dark" />
                                        </ComboBox>
                                    </StackPanel>
                                </Border>

                                <Border Classes="previewPanel">
                                    <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                                        <TextBlock Text="SQLite Database Preview" Classes="sectionTitle" />
                                        <TextBox x:Name="DatabasePreviewBox" Grid.Row="1" MinHeight="180" MaxHeight="260" AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True" Classes="mono" />
                                    </Grid>
                                </Border>

                                <Border Classes="softPanel">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Maintenance" Classes="sectionTitle" />
                                        <Button Classes="rail" Click="PreviewDatabase_Click" Content="Preview Database" />
                                        <Button Classes="rail" Click="ViewLogs_Click" Content="View Logs" />
                                        <Button Classes="rail" Click="CheckForUpdates_Click" Content="Check for Updates" />
                                        <Button Classes="rail" Click="OpenHelp_Click" Content="Open User Guide" />
                                        <Button Classes="rail" Click="OpenChangelog_Click" Content="View Changelog" />
                                        <Button Classes="rail" Click="OpenAbout_Click" Content="About IntelliFill OCR" />
                                    </StackPanel>
                                </Border>
                                <Border Classes="softPanel">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Application Status" Classes="sectionTitle" />
                                        <ScrollViewer MinHeight="150" MaxHeight="280" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                            <TextBlock x:Name="StatusText" TextWrapping="Wrap" Foreground="{DynamicResource MutedTextBrush}" />
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
